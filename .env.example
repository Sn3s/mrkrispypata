# Supabase (Project Settings → API). Copy this file to `.env.local` and fill in values.
# Restart `npm run dev` (or rebuild) after changes — Vite only reads env at startup.
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# Server-only: service role JWT for scripts/create-admin.mjs (never use as VITE_*)
# SUPABASE_SERVICE_ROLE_KEY=

# Optional — only if you use Gemini in the app
GEMINI_API_KEY=
